# Server
PORT=4000
NODE_ENV=development

# SQLite database path (relative to backend dir)
DB_PATH=./data/monitor.db

# Cron schedule for monitoring (default: every 6 hours)
MONITOR_CRON=0 */12 * * *

# Run a check on startup (true/false)
RUN_ON_STARTUP=true

# Optional SMTP (leave blank to disable email alerts)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Monitor <no-reply@example.com>"

# LINE Notify base URL (default: official endpoint)
LINE_NOTIFY_URL=https://notify-api.line.me/api/notify
